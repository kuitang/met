# Node / Expo
# no trailing slash: the dir-only form let a stray node_modules SYMLINK get
# committed by `git add -A` (apps/node_modules, snuck into main via #50)
node_modules
.expo/
.expo-shared/
dist/
web-build/

# Native build output
ios/
android/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# Metro
.metro-health-check*

# Env / secrets
.env
.env.*
!.env.example

# Logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# OS / editor
.DS_Store
*.pem
.idea/
.vscode/

# Test artifacts
coverage/
playwright-report/
test-results/
.playwright-mcp/

# Planning-session browser screenshots (competitive-study scratch, not deliverables)
/met-explorer-*.png

# Large local caches (re-fetchable; see data/src/embed-images.ts,
# data/src/thumbnails.ts — museum-keyed, one dir per registry museum)
data/raw/*-images/
data/raw/met-objects/

# Per-museum hydration resume caches (data/src/sources/*; re-fetchable)
data/raw/*/objects-cache.ndjson

# NGA opendata CSVs (~82 MB objects.csv; re-downloaded from the upstream repo)
data/raw/nga/

# Uffizi SPARQL page cache (data/src/sources/uffizi.ts; ~25 requests to
# re-fetch from dati.beniculturali.it)
data/raw/uffizi/

# Rijksmuseum OAI-PMH harvest state (data/src/sources/rijksmuseum.ts): the
# on-view id list + resumption-token position, both fully re-fetchable from
# data.rijksmuseum.nl (unlike Louvre's committed plan JSONs, there's no
# scraping-restriction reason to commit this raw data)
data/raw/rijksmuseum/

# Museo Egizio sitemap-crawl cache + harvest log (data/src/sources/egizio.ts;
# fully re-fetchable from collezioni.museoegizio.it)
data/raw/egizio/

# Reina Sofía page-data hydration cache (data/src/sources/reinasofia.ts;
# fully re-fetchable from museoreinasofia.es)
data/raw/reinasofia/

# Image-proxy disk cache (server/src/routes/img.ts; ephemeral in prod — it
# refills from the Met CDN after each deploy)
data/img-cache/

# Image-embedding vector index (~100 MB at full scale, rebuilt incrementally by
# data/src/embed-images.ts; server loads it from DATA_DIR — lives in the
# Tigris artifact bucket in prod, never in git). Museum-keyed: the Met's is at
# data/snapshots/, other museums' at data/museums/{id}/snapshots/.
data/snapshots/image-embeddings/
data/museums/*/snapshots/image-embeddings/

# Built data artifacts: the Tigris bucket (s3://met-artifacts) is the artifact
# registry — met.sqlite + VERSION are pulled from latest/ (CI, Docker bake; see
# data/src/fetch-artifacts.ts) or rebuilt locally via `npm -w data run
# build-db`. The reproducible SOURCES (snapshots/ geojson + graph + synonyms +
# objects snapshot, raw/ Living Map tiles) stay in git.
data/met.sqlite
data/met.sqlite.prev
data/VERSION

# Nightly pipeline scratch (data/src/nightly.ts)
data/.nightly/
